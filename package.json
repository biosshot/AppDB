{
  "name": "appdb",
  "version": "1.1.8",
  "description": "AppDB",
  "type": "module",
  "main": "./dist/appdb.cjs",
  "module": "./dist/appdb.esm.js",
  "browser": "./dist/appdb.umd.js",
  "types": "./dist/appdb.d.ts",
  "exports": {
    ".": {
      "types": "./dist/appdb.d.ts",
      "import": "./dist/appdb.esm.js",
      "require": "./dist/appdb.cjs",
      "browser": "./dist/appdb.umd.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rollup -c",
    "prepublishOnly": "npm run build",
    "test": "node --test tests/test.ts"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@types/node": "^25.5.0",
    "fake-indexeddb": "^6.2.5",
    "rollup": "^4.58.0",
    "rollup-plugin-dts": "^6.3.0"
  },
  "keywords": [
    "universal",
    "isomorphic",
    "node",
    "browser"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MarkMuravev/AppDB.git"
  },
  "author": "Mark Muravev <mark@echosystem.ru> (https://github.com/MarkMuravev)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/MarkMuravev/AppDB/issues"
  },
  "homepage": "https://github.com/MarkMuravev/AppDB#readme"
}
